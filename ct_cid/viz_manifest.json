      "provenance_url": "ct_cid/PROVENANCE.md",
      "parquet": "ct_cid/output/ct_complaints_yearly_confirmed.parquet",
      "x_field": "year_closed",
      "group_field": "coverage",
      "group_field_label": "Coverage",
      "metrics": [
        {"id": "against_rate_of_decided", "label": "Against-insurer rate (of decided)", "column": "against_rate_of_decided", "unit": "share"},
        {"id": "against_rate_of_total", "label": "Against-insurer rate (of total)", "column": "against_rate_of_total", "unit": "share"},
        {"id": "against_insurer", "label": "Against-insurer count", "column": "against_insurer"},
        {"id": "for_insurer", "label": "For-insurer count", "column": "for_insurer"},
        {"id": "ambiguous", "label": "Ambiguous count", "column": "ambiguous"},
        {"id": "no_disposition", "label": "No-disposition count", "column": "no_disposition"},
        {"id": "total", "label": "Total complaints", "column": "total"}
      ],
      "default_metric": "against_rate_of_decided",
      "default_groups": ["ALL"],
      "group_presets": [
        {"label": "Headline (ALL)", "groups": ["ALL"]},
        {"label": "All non-ALL lines", "exclude_groups": ["ALL"]},
        {"label": "All", "all": true}
      ],
      "partial_year": 2026,
      "outcome_buckets": {
        "aggregation": {"filter_to_group": "ALL"},
        "buckets": {
          "against_insurer": {"column": "against_insurer", "label": "Against insurer (regulator action favored consumer)"},
          "mixed":           null,
          "for_insurer":     {"column": "for_insurer", "label": "For insurer (Company Position Substantiated)"},
          "no_decision":     {"column": "no_decision", "label": "No merits decision (ambiguous + null disposition)"}
        }
      },
      "default_chart_mode": "two_panel"
    }
  ]
