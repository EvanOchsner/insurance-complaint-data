      "metrics": [
        {"id": "justified_per_100k_exposure", "label": "Justified per 100k exposure", "column": "justified_per_100k_exposure"},
        {"id": "total_justified_top50", "label": "Justified count (top-50 sum)", "column": "total_justified_top50"},
        {"id": "total_exposure_top50", "label": "Total exposure (top-50 sum)", "column": "total_exposure_top50"}
      ],
      "default_metric": "justified_per_100k_exposure",
      "default_groups": ["auto", "home", "life"],
      "group_presets": [
        {"label": "All lines", "all": true}
      ],
      "outcome_buckets": {
        "aggregation": {"sum_across_groups": true},
        "buckets": {
          "against_insurer": {"column": "total_justified_top50", "label": "Justified (CDI finding for consumer; top-50 only)"},
          "mixed":           null,
          "for_insurer":     null,
          "no_decision":     null
        }
      },
      "default_chart_mode": "stacked"
    },
    {
      "id": "ca_cdi_state",
