      "category": "regulator_finding",
      "jurisdiction": ["CA"],
      "year_field_label": "Year",
      "y_axis_label": "Justified complaints — top 50",
      "caveat_short": "CDI's `Justified` finding (CCR Title 10, Subch. 7.4): the licensee acted in contravention of statute, regulation, or contract. Sums cover only the top-50 insurers in CDI's most recent study covering each year — smaller carriers are not published.",
      "provenance_url": "ca_cdi/PROVENANCE.md",
      "parquet": "ca_cdi/output/ca_complaints_yearly_justified.parquet",
      "x_field": "year",
      "group_field": "line",
