        "VA"
      ],
      "year_field_label": "Fiscal year (FY ends Jun 30)",
      "y_axis_label": "External Review requests (VA SCC BOI)",
      "caveat_short": "Virginia health-insurance external-review dispositions — managed-care coverage appeals only. Cases that don't qualify are filtered out before they get a merits decision, so the against-insurer rate runs unusually high (~54%) compared to overall regulator-finding rates. Don't compare these directly to Maryland's 5.68%; the denominators are different.",
      "provenance_url": "va_scc/PROVENANCE.md",
      "parquet": "va_scc/output/va_external_review_yearly.parquet",
      "x_field": "fiscal_year",
      "group_field": null,
      "metrics": [
        {
          "id": "against_rate_of_decided",
          "label": "Against-rate (of decided)",
          "column": "against_rate_of_decided",
          "unit": "share"
        },
        {
          "id": "against_insurer",
          "label": "Against-insurer count",
          "column": "against_insurer"
        },
        {
          "id": "for_insurer",
          "label": "For-insurer count",
          "column": "for_insurer"
        },
        {
          "id": "mixed",
          "label": "Mixed (Modified)",
          "column": "mixed"
        },
        {
          "id": "no_decision",
          "label": "No decision (Ineligible + Terminated)",
          "column": "no_decision"
        },
        {
          "id": "total_reviewed",
          "label": "Total ER requests reviewed",
          "column": "total_reviewed"
        }
      ],
      "default_metric": "against_rate_of_decided",
      "outcome_buckets": {
        "buckets": {
          "against_insurer": {
            "column": "against_insurer",
            "label": "Overturned + Reversed-Itself (against insurer)"
          },
          "mixed": {
            "column": "mixed",
            "label": "Modified or Partially Overturned"
          },
          "for_insurer": {
            "column": "for_insurer",
            "label": "Upheld (for insurer)"
          },
          "no_decision": {
            "column": "no_decision",
            "label": "Ineligible + Terminated"
          }
        }
      },
      "default_chart_mode": "two_panel"
    }
  ]
