        {"id": "for_insurer", "label": "For-insurer count", "column": "for_insurer"},
        {"id": "mixed", "label": "Mixed (Modified)", "column": "mixed"},
        {"id": "no_decision", "label": "No decision (Ineligible + Terminated)", "column": "no_decision"},
